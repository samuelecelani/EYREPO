OPENID_OIDC = true
OPENID_SHOW_DEBUG_INFO = true
OPENID_REQUIRE_HTTPS = false
OPENID_SKIP_ISSUER_CHECK = true
OPENID_STRICT_DISCOVERY_DOC_VALIDATION = true
OPENID_PRESERVE_REQUEST_ROUTE = true
OPENID_TIMEOUT_FACTOR = 0.7

# Config FE - PDF quality thresholds
